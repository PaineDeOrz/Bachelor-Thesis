#!/bin/bash

#SBATCH --partition=slowlane
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --nodes=1
#SBATCH --mem=128G
#SBATCH --time=0-1:00:00
#SBATCH --gpus=A40:1
#SBATCH --output=%u_maia_train_%j.out
#SBATCH --job-name=maia-train

ulimit -n 65536

MAIA_DIR="/mnt/nfs/home/st188776/Cod/Antrenat/maia"

module load CUDA

# AUTO-DETECT CUDA PATH AND SET XLA_FLAGS
CUDA_PATH=$(which nvcc | sed 's|/bin/nvcc$||')
if [[ -z "$CUDA_PATH" ]]; then
    CUDA_PATH="$CUDA_HOME"
fi
if [[ -z "$CUDA_PATH" ]]; then
    CUDA_PATH="/usr/local/cuda"  # Common fallback
fi

# Verify libdevice exists
LIBDEVICE="$CUDA_PATH/nvvm/libdevice/libdevice.10.bc"
if [[ ! -f "$LIBDEVICE" ]]; then
    echo "WARNING: libdevice.10.bc not found at $LIBDEVICE"
    echo "Available CUDA paths:"
    find "$CUDA_PATH" -name "libdevice.*.bc" 2>/dev/null | head -3 || echo "No libdevice files found"
    # Fallback: disable XLA
    export XLA_FLAGS="--xla_gpu_disable=1"
else
    echo "Found CUDA at $CUDA_PATH (libdevice: $LIBDEVICE)"
    export XLA_FLAGS="--xla_gpu_cuda_data_dir=$CUDA_PATH"
fi

# Debug info
echo "XLA_FLAGS: $XLA_FLAGS"
echo "CUDA_HOME: $CUDA_HOME"
nvidia-smi | head -5

source /mnt/nfs/home/st188776/Cod/.venv/bin/activate

cd /mnt/nfs/home/st188776/Cod/Antrenat/maia

export PATH="$HOME/Cod/Antrenat/bin:$PATH"

python move_prediction/train_maia.py /mnt/nfs/home/st188776/Cod/Antrenat/maia/move_prediction/maia_config.yaml