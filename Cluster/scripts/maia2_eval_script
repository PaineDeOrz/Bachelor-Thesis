#!/bin/bash

#SBATCH --partition=slowlane

#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --nodes=1
#SBATCH --mem=128G
#SBATCH --time=0-12:00:00
#SBATCH --gpus=A40:1
#SBATCH --output=%u_maia2_eval_%j.out
#SBATCH --job-name=maia2-eval

echo "Job started: $(date)"
echo "Node: $SLURM_NODELIST"
echo "GPUs allocated: $SLURM_GPUS_PER_NODE"

module load CUDA

nvidia-smi
python -c "import torch; print(f'CUDA available: {torch.cuda.is_available()}, device: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else \"none\"}')"

source /mnt/nfs/home/st188776/Cod/.venv/bin/activate

cd /mnt/nfs/home/st188776/Cod/Antrenat/maia2/maia2

python cluster_eval.py
