#!/bin/bash
#SBATCH --job-name=lczero-train
#SBATCH --partition=slowlane
#SBATCH --gpus=A40:2
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=128G
#SBATCH --time=0-01:00:00
#SBATCH --output=lczero_%u_job_%j.out

ulimit -n 16384
ulimit -u 20000

## Paths
LCZERO_DIR="/mnt/nfs/home/st188776/Cod/Antrenat/lczero-training"
TF_DIR="${LCZERO_DIR}/tf"
NETS_DIR="${LCZERO_DIR}/created_nets"
cd ${TF_DIR}

module load CUDA

source /mnt/nfs/home/st188776/Cod/.venv/bin/activate

cd ${TF_DIR}

# Ensure directories
mkdir -p ${NETS_DIR} created_nets

# Run training
echo "Starting LCZero training..."
python train.py --cfg configs/example.yaml --output lczero-training-${SLURM_JOB_ID}.log

# Copy results
cp -r created_nets/* ${NETS_DIR}/ 2>/dev/null || true
echo "Results copied to ${NETS_DIR}/"
ls -la ${NETS_DIR}/